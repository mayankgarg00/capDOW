# CapDAO Backend Environment Variables
# Copy this to .env and fill in your values

# MongoDB Atlas connection string (optional — app falls back to memory if not set)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://Mayank:123456789@@cluster0.ht9jqwf.mongodb.net/capdao?retryWrites=true&w=majority&appName=Cluster0

# Server port (default: 5000)
PORT=5000
